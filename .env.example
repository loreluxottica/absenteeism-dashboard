# Copy this file to ".env" and fill in your own values.
# Get a Mapbox public token at https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=your_mapbox_public_token_here
# Optional: a custom Mapbox style URL. Defaults to mapbox://styles/mapbox/dark-v11
MAPBOX_STYLE=mapbox://styles/mapbox/dark-v11
